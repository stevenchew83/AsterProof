# Local development defaults
DJANGO_DEBUG=True

# Prefer a local PostgreSQL database that matches production semantics more closely.
# This default uses the current OS user over the local PostgreSQL socket.
DATABASE_URL=postgresql:///asterproof

# Set your own secret key if you do not want to use the fallback from local settings.
# DJANGO_SECRET_KEY=change-me

# Temporary production bootstrap overrides if you need to bring the site up on plain HTTP
# before a real HTTPS certificate is installed. Leave these unset in steady-state production.
# DJANGO_SESSION_COOKIE_SECURE=False
# DJANGO_CSRF_COOKIE_SECURE=False
